# region File IO
def IO_RealPath(filePath):
    return os.path.realpath(os.path.expanduser(filePath))
def IO_GetEnvironmentDir():
    ENV_NAME = os.path.basename(os.path.dirname(os.path.abspath(__file__)))
    return os.path.join("/nfs/stak/users/christj/", ENV_NAME)
def IO_WriteFile(filePath, contents, binary=False):
    filePath = IO_RealPath(filePath)
    if binary:
        with open(filePath, "wb") as f:
            f.write(contents)
    else:
        with codecs.open(filePath, "w", encoding="utf-8") as f:
            f.write(contents)
def IO_AppendFile(filePath, contents, binary=False):
    filePath = IO_RealPath(filePath)
    if binary:
        with open(filePath, "ab") as f:
            f.write(contents)
    else:
        with codecs.open(filePath, "a", encoding="utf-8") as f:
            f.write(contents)
def IO_CreateFile(filePath, contents, mode, binary=False):
    filePath = IO_RealPath(filePath)
    fd = os.open(filePath, os.O_WRONLY | os.O_CREAT | os.O_EXCL, mode)
    try:
        if binary:
            with os.fdopen(fd, "wb") as f:
                f.write(contents)
        else:
            with io.open(fd, "w", encoding="utf-8") as f:
                f.write(contents)
    except Exception:
        try:
            os.close(fd)
        except OSError:
            pass
        raise
def IO_ReadFile(filePath, defaultContents=None, binary=False):
    filePath = IO_RealPath(filePath)
    try:
        if binary:
            with open(filePath, "rb") as f:
                return f.read()
        else:
            with codecs.open(filePath, "r", encoding="utf-8") as f:
                return f.read()
    except IOError as ex:
        if ex.args[0] == errno.ENOENT and defaultContents != None:
            return defaultContents
        else:
            raise
    if defaultContents != None and not os.path.exists(filePath):
        return defaultContents
def IO_SerializeJson(obj, compact=False):
    return json.dumps(obj, separators=(',', ':') if compact else None, indent=None if compact else 4)
def IO_DeserializeJson(jsonString):
    return json.loads(jsonString)
def IO_GetEpoch():
    return time.time()
def IO_FormatEpoch(epoch):
    timestamp = datetime.datetime.fromtimestamp(epoch)
    formatted = timestamp.strftime("%I:%M%p %m/%d").lower()
    return formatted.decode("utf-8")
# endregion

# region Logs
def LOG_Generic(message, log_type):
    formatted_message = "CGI - {} - {} {} - {}".format(log_type, IO_FormatEpoch(IO_GetEpoch()), int(IO_GetEpoch()), message)
    log_path = os.path.join(IO_GetEnvironmentDir(), "log.txt")
    if not os.path.exists(log_path):
        IO_CreateFile(log_path, "{}\n".format(formatted_message), 0o600)
    else:
        IO_AppendFile(log_path, "{}\n".format(formatted_message))
def LOG_Info(message):
    LOG_Generic(message, "Info")
def LOG_Warning(message):
    LOG_Generic(message, "Warning")
def LOG_Error(message):
    LOG_Generic(message, "ERROR")
def LOG_Exception(ex):
    _, _, tb = sys.exc_info()
    tb_data = None
    while tb is not None:
        if IO_RealPath(tb.tb_frame.f_code.co_filename) == IO_RealPath(__file__):
            message = repr(ex)
            funcname = "<module>" if tb.tb_frame.f_code.co_name == "<module>" else tb.tb_frame.f_code.co_name + "()"
            lineno = tb.tb_lineno
            line = IO_ReadFile(tb.tb_frame.f_code.co_filename).splitlines()[lineno - 1].strip()
            tb_data = { "message": message, "funcname": funcname, "lineno": lineno, "line": line }
        tb = tb.tb_next
    if tb_data == None:
        LOG_Generic("{} at unknown location".format(repr(ex)), "PY_EX")
    else:
        LOG_Generic("{} in {} line {}: {}".format(tb_data['message'], tb_data['funcname'], tb_data['lineno'], tb_data['line']), "PY_EX")
# endregion

# region Environment
ENV = None
def ENV_Load():
    global ENV
    env_path = os.path.join(IO_GetEnvironmentDir(), "environment.json")
    ENV = IO_DeserializeJson(IO_ReadFile(env_path))
# endregion

def Main():
    code = os.environ.get("QUERY_STRING", "").replace("\n", "").replace("\r", "")
    for hostname in ENV["api_hosts"]:
        sock = None
        sockfile = None
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(1.0) # Host needs to connect within 1 second
            sock.connect((hostname, ENV["api_port"]))
            sock.settimeout(30.0) # Host can have up to 30 seconds to reply once connected
            sock.sendall((code + "\n").encode("utf-8"))
            sockfile = sock.makefile("rb", 0)
            return sockfile.readline(65536).decode("utf-8").rstrip("\n")
        except socket.error as ex:
            if ex.args[0] == errno.ECONNREFUSED:
                continue
            else:
                raise ex
        finally:
            if sockfile:
                sockfile.close()
            if sock:
                sock.close()
    LOG_Error("All API servers are down!")
    return IO_SerializeJson({ "state": "error", "title": "An Error Occurred", "message": "Please DM @finlaytheberry to report this issue.<br />Error details: All api servers are down." }, compact=True)

print("Content-Type: application/json")
print("")
try:
    ENV_Load()
    print(Main())
except Exception as ex:
    LOG_Exception(ex)
    print(IO_SerializeJson({ "state": "error", "title": "An Error Occurred", "message": "Please DM @finlaytheberry to report this issue.<br />Error details: An internal server error occured." }, compact=True))